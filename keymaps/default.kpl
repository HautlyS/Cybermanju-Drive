[Global]
name=Cybermanju Default
version=1.2
description=Default keyboard & touchpad profile for Cybermanju Drive

[Global Shortcuts]
toggle_sidebar=Ctrl+B
toggle_palette=Ctrl+P
toggle_help=Ctrl+/
focus_search=Ctrl+F
new_folder=Ctrl+Shift+N
upload_file=Ctrl+U
refresh=Ctrl+R
toggle_dark_mode=Ctrl+D
escape=Escape
toggle_fullscreen=F11

[Navigation]
go_back=Alt+Left
go_forward=Alt+Right
go_up=Alt+Up
go_home=Alt+Home
focus_grid=Ctrl+1
focus_sidebar=Ctrl+2
focus_right_panel=Ctrl+3
focus_search_panel=Ctrl+4
prev_panel=Ctrl+Tab
next_panel=Ctrl+Shift+Tab

[File Operations]
delete=Delete
rename=F2
copy=Ctrl+C
cut=Ctrl+X
paste=Ctrl+V
select_all=Ctrl+A
deselect=Escape
open=Enter
preview=Space
star_file=Ctrl+S
compress=Ctrl+Shift+C
encrypt=Ctrl+Shift+E
download=Ctrl+D
file_properties=Alt+Enter
show_permissions=Ctrl+Shift+P
duplicate=Ctrl+D
rotate_cw=Ctrl+Shift+R
rotate_ccw=Ctrl+Alt+R

[View]
toggle_grid=Ctrl+Shift+1
toggle_list=Ctrl+Shift+2
toggle_masonry=Ctrl+Shift+3
toggle_details=Ctrl+Shift+4
sort_name=Ctrl+Shift+N
sort_date=Ctrl+Shift+D
sort_size=Ctrl+Shift+S
sort_type=Ctrl+Shift+T
toggle_hidden=Ctrl+H
zoom_in=Ctrl+=
zoom_out=Ctrl+-

[Panels]
open_trash=Ctrl+T
open_activity=Ctrl+Shift+A
open_collections=Ctrl+Shift+O
open_faces=Ctrl+Shift+F
open_map=Ctrl+Shift+M
open_code=Ctrl+Shift+K
open_settings=Ctrl+,
open_storage=Ctrl+Shift+S
open_favorites=Ctrl+Shift+F

[Touch]
swipe_threshold=50
long_press_threshold=600
edge_zone_size=30
double_tap_timeout=300
auto_detect_touch=true
